# .env.local - プロジェクト直下に置いてください
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyC6AZfNZYB8R53laqA9SyOrFqIe0U8Cnxs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=online-ito.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=online-ito
NEXT_PUBLIC_FIREBASE_APP_ID=1:374128501058:web:ae672cc7dc71a60c4e28db

# 任意（あるなら入れておくと便利）
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=online-ito.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=374128501058
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-WV2ZJ6CP5H
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://online-ito-default-rtdb.asia-southeast1.firebasedatabase.app

# ロビー人数のFirestoreフォールバックを停止（presenceのみ使用）
NEXT_PUBLIC_DISABLE_FS_FALLBACK=1

# 必要に応じてロビーの鮮度/ゼロ据え置き時間を調整（ミリ秒）
# デフォルト: LOBBY_STALE_MS=8000, ZERO_FREEZE_MS=20000
# NEXT_PUBLIC_LOBBY_STALE_MS=8000
# NEXT_PUBLIC_LOBBY_ZERO_FREEZE_MS=20000
NEXT_PUBLIC_LOBBY_DEBUG_UIDS=0
NEXT_PUBLIC_LOBBY_VERIFY_SINGLE=1

# Presence チューニング（本番既定値）
NEXT_PUBLIC_PRESENCE_HEARTBEAT_MS=20000
NEXT_PUBLIC_PRESENCE_STALE_MS=45000
NEXT_PUBLIC_PRESENCE_MAX_CLOCK_SKEW_MS=30000


# Stripe 設定（サーバー側鍵は公開リポジトリにコミットしないでください）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2025-08-27.basil
STRIPE_DONATION_CURRENCY=jpy
STRIPE_PRICE_DONATION_SUPPORTER=price_test_supporter_xxxxxxxxxxxxx
STRIPE_PRICE_DONATION_CHAMPION=price_test_champion_xxxxxxxxxxxxxx
STRIPE_PRICE_DONATION_LEGEND=price_test_legend_xxxxxxxxxxxxxxxx
STRIPE_ALLOWED_RETURN_URLS=["http://localhost:3000","https://example.com"]
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/support/thanks
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/support/cancelled
STRIPE_EVENT_TTL_DAYS=30
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_UI_ENABLED=0


# Firebase Emulator Suite を使う場合（開発用）   firebase emulators:start

# ローカルでエミュレータを起動している場合に有効にしてください
# 参考: https://firebase.google.com/docs/emulator-suite/connect_firestore?hl=ja&platform=web
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=false
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_AUTH_EMULATOR_HOST=localhost
NEXT_PUBLIC_AUTH_EMULATOR_PORT=9099
NEXT_PUBLIC_DATABASE_EMULATOR_HOST=localhost
NEXT_PUBLIC_DATABASE_EMULATOR_PORT=9000

NEXT_PUBLIC_LOG_LEVEL=info

# クライアント側のFPS/INPメトリクスを一時停止したい場合はコメントを外して1に設定
NEXT_PUBLIC_DISABLE_CLIENT_METRICS=0
# Sentry 連携（コメントを外すと有効化）
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# PWA を無効にしたい場合は 0 を指定
NEXT_PUBLIC_ENABLE_PWA=1
NEXT_PUBLIC_FEATURE_SAFE_UPDATE=1
NEXT_PUBLIC_FEATURE_IDLE_APPLY_MS=30000
NEXT_PUBLIC_FORCE_DETACH_ON_LEAVE=1  # タブ終了時に presence を即除去する（0 にすると複数端末を許容）


# メトリクス HUD を有効にする場合のみ 1 に設定（デフォルトは 0）
NEXT_PUBLIC_DEBUG_METRICS=1
NEXT_PUBLIC_ENABLE_RENDER_METRICS=1 
# NEXT_PUBLIC_APP_VERSION=2025-10-23-01

# 観戦モードV3（Recall V2）を有効化
NEXT_PUBLIC_RECALL_V2=1

# --- パフォーマンス: 初回/タブ復帰直後のウォームアップ設定 ---------------------------------
# 0: 無効（既定） / 1: 有効
# 有効化すると、
# - Sound: 初回入力/可視化で AudioContext を再開し主要SFXを事前デコード
# - Pixi: 初期化直後に空描画でGPUを軽く起こす
# - Firestore購読: 初回のみ1フレーム遅延 + 重め購読は約50ms遅延
# 既存のUIやゲーム挙動は変わりません。初回だけ滑らかさを優先します。
NEXT_PUBLIC_PERF_WARMUP=1

# --- 据え置き体感向上フラグ（ロールアウト検証用） --------------------------------
# INP 計測に trace/phase 情報を紐づける（1で有効）
NEXT_PUBLIC_PERF_INTERACTION_TAGS=1
# ルーム/参加者スナップショットを遅延コミット＆計測する（1で有効）
NEXT_PUBLIC_PERF_ROOM_SNAPSHOT_DEFER=1
# ポインタ入力で AudioContext を即時再開し発音ラグを計測する（1で有効）
NEXT_PUBLIC_AUDIO_RESUME_ON_POINTER=1
# カードドロップを楽観反映し resolve 時間を計測する（1で有効）
NEXT_PUBLIC_UI_DROP_OPTIMISTIC=1

# dumpItoMetrics();
# window.__ITO_METRICS__?.app?.appVersion
